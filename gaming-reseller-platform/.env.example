# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy to .env for local dev, or add to Koyeb/Railway settings
# ============================================================

PORT=5000
NODE_ENV=production

# MongoDB Atlas URI (https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/gaming_reseller?retryWrites=true&w=majority

# JWT (use long random strings)
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string
JWT_REFRESH_EXPIRE=30d

# Frontend URL (your Vercel URL — no trailing slash)
CLIENT_URL=https://dash-board-delta-snowy.vercel.app

# Gmail (use App Password, not real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=ahmadhzahidh215@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password
EMAIL_FROM=PRRX Gaming <ahmadhzahidh215@gmail.com>

# Admin credentials
ADMIN_EMAIL=admin@gamingreseller.com
ADMIN_PASSWORD=Admin@123456

# Session
SESSION_SECRET=replace_with_random_session_secret

# WhatsApp
WHATSAPP_NUMBER=94742560815
