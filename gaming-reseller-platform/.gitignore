# ── Dependencies ──────────────────────────────────────────────
node_modules/
client/node_modules/

# ── Secrets (NEVER commit) ────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Build output ──────────────────────────────────────────────
client/build/
dist/
build/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ── Uploads (keep folder, ignore files) ──────────────────────
uploads/products/*
uploads/avatars/*
uploads/banners/*
uploads/backgrounds/*
uploads/videos/*
!uploads/products/.gitkeep
!uploads/avatars/.gitkeep
!uploads/banners/.gitkeep
!uploads/backgrounds/.gitkeep
!uploads/videos/.gitkeep

# ── Dev-only scripts ──────────────────────────────────────────
gen_*.js
fix_*.js

# ── MongoDB memory server ─────────────────────────────────────
.mongodb-binaries/
node_modules/.cache/

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/
